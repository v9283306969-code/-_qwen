# ========================================
# MLECP — Environment Variables Template
# ========================================
# Скопируйте этот файл в .env.local и заполните значениями.
# cp .env.example .env.local
# НЕ коммитьте .env.local в репозиторий!
# ========================================

# --- Инфраструктура ---

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=dev
DB_PASS=dev_secure_password_123
DB_NAME=mlecp_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- JWT ---

JWT_SECRET=generate_random_256bit_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ACCESS_TOKEN_SECRET=${JWT_SECRET}
REFRESH_TOKEN_SECRET=generate_another_random_256bit_secret

# --- Сервисы (внутренние URL для docker-compose) ---

PRODUCT_SERVICE_URL=http://product-service:3001
ORDER_SERVICE_URL=http://order-service:3002
PARTNER_SERVICE_URL=http://partner-service:3003

# Порты сервисов (локальные)
GATEWAY_PORT=4000
PRODUCT_SERVICE_PORT=3001
ORDER_SERVICE_PORT=3002
PARTNER_SERVICE_PORT=3003

# --- Strapi CMS ---

STRAPI_URL=http://strapi:1337
STRAPI_API_KEY=your_strapi_api_key_here
APP_KEYS=temp_key_1,temp_key_2
ADMIN_JWT_SECRET=change_me_strapi_admin_secret

# --- ЮKassa ---

YOOKASSA_SHOP_ID=change_me
YOOKASSA_SECRET_KEY=change_me
YOOKASSA_RETURN_URL=http://localhost:3000/checkout/success

# --- СДЭК ---

CDEK_ACCOUNT=change_me
CDEK_SECRET=change_me
CDEK_BASE_URL=https://api.cdek.ru/v2

# --- Мониторинг (Sentry) ---

SENTRY_DSN=
# Пример: https://xxxxxxx@o123456.ingest.sentry.io/123456

# --- Фронтенд (публичные переменные) ---

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin Panel ---

ADMIN_API_URL=http://localhost:4000
ADMIN_SITE_URL=http://localhost:3001
