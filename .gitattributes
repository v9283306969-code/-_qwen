# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare text files
*.md text
*.txt text
*.yml text
*.yaml text
*.json text
*.toml text
*.xml text
*.html text
*.css text
*.js text
*.ts text
*.tsx text
*.jsx text
*.py text
*.graphql text

# Binary files - keep as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
